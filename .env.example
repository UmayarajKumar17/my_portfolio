# =============================================================
# LOCAL DEVELOPMENT — Copy this file to .env and fill in values
# NEVER commit .env to git — it is in .gitignore
# =============================================================

# For local dev: calls Groq directly (key stays on your machine only)
# Get your API key from https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# For production (GitHub Pages): set this in GitHub Secrets as VITE_CHAT_API_URL
# This should point to your deployed Vercel proxy (portfolio-tracker-api/api/chat.js)
# Example: https://portfolio-tracker-api-xxx.vercel.app/api/chat
# Leave blank for local dev (direct key above is used instead)
VITE_CHAT_API_URL=

# EmailJS Configuration (optional)
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key
